# Reader API public access token used by the mobile app.
READER_API_TOKEN=change-me-to-a-long-random-token

# Host port exposed by the Reader API container.
READER_API_PORT=8787
PORT=8787

# Existing TeslaMate Docker network.
# If TeslaMate was started from a directory named "teslamate", this is usually teslamate_default.
TESLAMATE_DOCKER_NETWORK=teslamate_default

# Existing TeslaMate PostgreSQL service.
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_NAME=teslamate

# Prefer a PostgreSQL read-only user. For a quick private-network smoke test,
# this can temporarily match the TeslaMate DB user, then be replaced.
DATABASE_USER=teslamate_readonly
DATABASE_PASSWORD=change-me
DATABASE_SSL=false
